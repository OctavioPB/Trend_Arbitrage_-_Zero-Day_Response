# ────────────────────────────────────────────────────────────────────────────
# Trend Arbitrage & Zero-Day Response — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────────────────────────

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Kafka ───────────────────────────────────────────────────────────────────
# From outside Docker (local scripts, tests): localhost:9092
# From inside Docker (Airflow DAGs):          kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw_signals
KAFKA_TOPIC_ENRICHED=enriched_signals
KAFKA_TOPIC_GOLDEN=golden_record_ready

# ─── Data Sources ────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=trend-arbitrage/1.0

TWITTER_BEARER_TOKEN=...

# ─── Database ────────────────────────────────────────────────────────────────
# From outside Docker (local scripts, migrations): localhost:5432
# From inside Docker (Airflow DAGs, API):          postgres:5432
POSTGRES_DSN=postgresql://trend:trend@localhost:5432/trend_arbitrage

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Pipeline ────────────────────────────────────────────────────────────────
MPI_THRESHOLD=0.72
SIGNAL_WINDOW_MINUTES=60

# ─── LLM ─────────────────────────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=512

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Airflow ─────────────────────────────────────────────────────────────────
# Must match your host user UID to avoid volume permission errors.
# Run:  echo "AIRFLOW_UID=$(id -u)"
AIRFLOW_UID=50000
# Generate Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_KEY
# Generate secret key:  python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=REPLACE_WITH_RANDOM_STRING
