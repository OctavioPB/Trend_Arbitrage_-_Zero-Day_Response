# ────────────────────────────────────────────────────────────────────────────
# Trend Arbitrage & Zero-Day Response — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────────────────────────

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Kafka ───────────────────────────────────────────────────────────────────
# From outside Docker (local scripts, tests): localhost:9092
# From inside Docker (Airflow DAGs):          kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw_signals
KAFKA_TOPIC_ENRICHED=enriched_signals
KAFKA_TOPIC_GOLDEN=golden_record_ready

# ─── Data Sources ────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=trend-arbitrage/1.0

TWITTER_BEARER_TOKEN=...
TWITTER_FILTER_TERMS=openai,anthropic,llm,ai chips

# ─── LinkedIn (F3) ───────────────────────────────────────────────────────────
# RapidAPI key — subscribe at rapidapi.com/rockapis-rockapis-default/api/linkedin-data-scraper
RAPIDAPI_KEY=...
# Comma-separated LinkedIn company slugs (as they appear in linkedin.com/company/<slug>/)
LINKEDIN_COMPANY_HANDLES=openai,anthropic,google-deepmind,microsoft
LINKEDIN_POLL_INTERVAL=600
LINKEDIN_POSTS_PER_HANDLE=10

# ─── News (F3) ───────────────────────────────────────────────────────────────
# NewsAPI key — get one free at newsapi.org
NEWSAPI_KEY=...
# Comma-separated keywords / phrases to query
NEWS_KEYWORDS=artificial intelligence,AI chips,large language models,generative AI
NEWS_POLL_INTERVAL=300
NEWSAPI_LANGUAGE=en
NEWSAPI_PAGE_SIZE=50
# Set to "false" to disable the free GDELT secondary source
GDELT_ENABLED=true
GDELT_MAX_RECORDS=25

# ─── RSS (F3) ────────────────────────────────────────────────────────────────
# Path to feed list (default: config/rss_feeds.json)
RSS_FEEDS_PATH=config/rss_feeds.json
RSS_POLL_INTERVAL=900

# ─── Source weights (F3) ─────────────────────────────────────────────────────
# Path to per-source MPI weight multipliers (default: config/source_weights.json)
SOURCE_WEIGHTS_PATH=config/source_weights.json

# ─── Database ────────────────────────────────────────────────────────────────
# From outside Docker (local scripts, migrations): localhost:5432
# From inside Docker (Airflow DAGs, API):          postgres:5432
POSTGRES_DSN=postgresql://trend:trend@localhost:5432/trend_arbitrage

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Pipeline ────────────────────────────────────────────────────────────────
MPI_THRESHOLD=0.72
SIGNAL_WINDOW_MINUTES=60

# ─── LLM ─────────────────────────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=512

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Authentication (F4) ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=REPLACE_WITH_RANDOM_HEX_32_BYTES
# Admin credentials for POST /auth/token (OAuth2 password grant)
API_ADMIN_USER=admin
API_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# JWT lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Rate limits — requests per IP per minute
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_WRITE_PER_MINUTE=20

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Airflow ─────────────────────────────────────────────────────────────────
# Must match your host user UID to avoid volume permission errors.
# Run:  echo "AIRFLOW_UID=$(id -u)"
AIRFLOW_UID=50000
# Generate Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_KEY
# Generate secret key:  python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=REPLACE_WITH_RANDOM_STRING

# ─── Alerting (F1) ───────────────────────────────────────────────────────────
# URL shown in alert messages as a "View Dashboard" link
DASHBOARD_URL=http://localhost:5173

# Slack — Incoming Webhook URL from api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Generic webhook — URL + optional auth header value
ALERT_WEBHOOK_URL=https://your-service.example.com/hook
ALERT_WEBHOOK_TOKEN=...

# SMTP (email alerts) — example uses Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=you@gmail.com
# Comma-separated list of recipient addresses
ALERT_TO_EMAILS=team@example.com,oncall@example.com
